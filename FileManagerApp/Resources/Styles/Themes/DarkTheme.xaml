<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Dark Theme Colors -->
    <Color x:Key="BackgroundColor">#0a0e1a</Color>
    <Color x:Key="SurfaceColor">#1e293b</Color>
    <Color x:Key="PrimaryColor">#3b82f6</Color>
    <Color x:Key="SecondaryColor">#8b5cf6</Color>
    <Color x:Key="TextPrimaryColor">#f8fafc</Color>
    <Color x:Key="TextSecondaryColor">#94a3b8</Color>
    <Color x:Key="AccentColor">#3b82f6</Color>
    <Color x:Key="SuccessColor">#22c55e</Color>
    <Color x:Key="WarningColor">#f59e0b</Color>
    <Color x:Key="DangerColor">#ef4444</Color>
    <Color x:Key="BorderColor">#334155</Color>

</ResourceDictionary>
